# Project-local npm config for THEBLACKLIST.ONLINE.
# Keep this file limited to valid npm config keys.
#
# Do not add `http-proxy` here. npm warns:
#   npm warn Unknown env config "http-proxy". This will stop working in the next major version of npm.
#
# If a proxy is required, use npm's supported keys in a user/CI environment instead:
#   npm config set proxy http://user:pass@host:port
#   npm config set https-proxy http://user:pass@host:port
#   npm config set noproxy localhost,127.0.0.1

fund=false
audit=true
