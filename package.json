{
  "name": "thegreenlist-online",
  "version": "1.0.0",
  "description": "A cannabis transparency, accountability, education, reporting, news, forum, and community trust platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint .",
    "test": "prisma validate",
    "dns:list": "npx ts-node scripts/porkbun-dns.ts list",
