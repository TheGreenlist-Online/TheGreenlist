    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.38.4",
    "@tanstack/react-query": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^4.24.5",
    "openai": "^4.11.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.3.6",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
