# Production Domain
NEXT_PUBLIC_SITE_URL=https://theblacklist.online
NEXT_PUBLIC_DOMAIN=theblacklist.online

# Database
DATABASE_URL="postgresql://username:password@db.theblacklist.online:5432/theblacklist"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
CLERK_WEBHOOK_SECRET=whsec_...

# Supabase (for file storage)
NEXT_PUBLIC_SUPABASE_URL=https://...theblacklist...supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Vercel Deployment
VERCEL_ENV=production
VERCEL_URL=theblacklist.online

# Optional: Redis caching
REDIS_URL=redis://cache.theblacklist.online:6379

# Local Development
# NEXT_PUBLIC_SITE_URL=http://localhost:3000