# ============================================================================
# The Green List Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# Never commit real secrets to the repository.

# ============================================================================
# Site Configuration
# ============================================================================
NEXT_PUBLIC_APP_URL="https://greenlist.online"
NEXT_PUBLIC_SECONDARY_APP_URL="https://thegreenlist.online"
NEXT_PUBLIC_SITE_NAME="The Green List"
NEXT_PUBLIC_SITE_URL="https://greenlist.online"

# ============================================================================
# Supabase Auth / Client Environment (REQUIRED)
# ============================================================================
# Supabase Auth is the primary authentication system.
# auth.users.id is the canonical user ID.
# public.profiles.id should reference auth.users.id.
NEXT_PUBLIC_SUPABASE_URL="https://idtnlninotxwqpznbwur.supabase.co"

# Use the publishable key (preferred) or anon key (legacy fallback).
# The app prefers NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY over NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="replace-with-supabase-publishable-key"

# Legacy fallback (only if publishable key is unavailable; rarely needed)
# NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"

# ============================================================================
# Supabase Server-only Environment (OPTIONAL)
# ============================================================================
# Only required if the app has protected server-side admin tasks that need elevated Supabase access.
# Never expose this in browser code. Use only for trusted admin/server operations.
# SUPABASE_URL="https://idtnlninotxwqpznbwur.supabase.co"
# SUPABASE_SECRET_KEY="replace-with-supabase-secret-key"

# Legacy fallback (only if secret key is unavailable; rarely needed)
# SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# ============================================================================
# Optional Prisma / PostgreSQL Direct Access
# ============================================================================
# DATABASE_URL is optional and only needed if using Prisma for application data beyond auth.
# The app does NOT require DATABASE_URL for Supabase Auth to work.
# Vercel builds succeed without this variable.
# Leave blank or omit to build with Supabase Auth only.
# DATABASE_URL="postgresql://username:password@host:5432/thegreenlist"

# ============================================================================
# Deprecated NextAuth Configuration (NOT USED - for reference only)
# ============================================================================
# NextAuth has been deprecated. Supabase Auth is the active authentication system.
# These values are no longer needed. Leave empty or omit.
# NEXTAUTH_URL="https://greenlist.online"
# NEXTAUTH_SECRET="replace-with-legacy-nextauth-value"

# Deprecated OAuth providers (use Supabase dashboard to configure):
# GOOGLE_CLIENT_ID="replace-with-legacy-google-client-id"
# GOOGLE_CLIENT_SECRET="replace-with-legacy-google-secret"
# APPLE_ID="replace-with-legacy-apple-id"
# APPLE_SECRET="replace-with-legacy-apple-secret"

# ============================================================================
# Porkbun Domain Management
# ============================================================================
PORKBUN_API_KEY="replace-with-porkbun-api-key"
PORKBUN_API_SECRET="replace-with-porkbun-api-secret"
PORKBUN_DOMAIN="greenlist.online"
PORKBUN_SECONDARY_DOMAIN="thegreenlist.online"

# ============================================================================
# Vercel DNS Records (Current Values - Do Not Modify Unless Redeploying)
# ============================================================================
# These are the current Vercel-managed DNS record values.
# Update only if you redeploy to a new Vercel project.
VERCEL_APEX_A_RECORD="76.76.19.19"
VERCEL_WWW_CNAME_RECORD="cname.vercel-dns.com"
INCLUDE_API_SUBDOMAIN="false"

# ============================================================================
# n8n Automation Framework (Optional - Not Required for Build)
# ============================================================================
# Leave blank or commented out if not using n8n workflows yet.
# N8N_WEBHOOK_URL="https://n8n.your-domain.com/webhook/"
# N8N_API_KEY="replace-with-n8n-api-key"

# ============================================================================
# Optional AI & Services
# ============================================================================
OPENAI_API_KEY="replace-with-openai-api-key"
RESEND_API_KEY="replace-with-resend-api-key"

# ============================================================================
# Monitoring & Analytics
# ============================================================================
# VERCEL_ANALYTICS_ID="replace-with-vercel-analytics-id"
# SENTRY_DSN="replace-with-sentry-dsn"

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_AI_MODERATION="true"
ENABLE_FORUMS="true"
ENABLE_REVIEWS="true"
