# Site Configuration
NEXT_PUBLIC_SITE_URL="https://theblacklist.online"
NEXT_PUBLIC_DOMAIN="theblacklist.online"

# Clerk Authentication (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
CLERK_SECRET_KEY="your-clerk-secret-key"

# Porkbun Domain Management (https://porkbun.com)
PORKBUN_API_KEY="your-porkbun-api-key"
PORKBUN_API_SECRET="your-porkbun-api-secret"
PORKBUN_DOMAIN="theblacklist.online"

# Database (PostgreSQL or Supabase)
# Local development:
# DATABASE_URL="postgresql://username:password@localhost:5432/theblacklist"
# Production (Supabase):
# DATABASE_URL="postgresql://username:password@db.supabase.co:5432/postgres"
DATABASE_URL="postgresql://username:password@db.theblacklist.online:5432/theblacklist"

# Optional Services
OPENAI_API_KEY="your-openai-api-key"
REDIS_URL="redis://cache.theblacklist.online:6379"

# Supabase (for file storage)
SUPABASE_URL="your-supabase-project-url"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Email Service
RESEND_API_KEY="your-resend-api-key"

# Analytics and Monitoring
VERCEL_ANALYTICS_ID="your-vercel-analytics-id"
SENTRY_DSN="your-sentry-dsn"

# Feature Flags
ENABLE_AI_MODERATION="true"
ENABLE_FORUMS="true"
ENABLE_REVIEWS="true"
