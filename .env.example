# ============================================================================
# The Green List Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# Never commit real secrets to the repository.

# ============================================================================
# Site Configuration
# ============================================================================
NEXT_PUBLIC_SITE_URL="https://thegreenlist.online"
NEXT_PUBLIC_APP_URL="https://thegreenlist.online"
NEXT_PUBLIC_SITE_NAME="The Green List"
NEXT_PUBLIC_DOMAIN="thegreenlist.online"
NEXT_PUBLIC_SECONDARY_DOMAIN="greenlist.online"

# ============================================================================
# Supabase Auth / Client Environment
# ============================================================================
# Supabase Auth is the primary authentication system.
# auth.users.id is the canonical user ID.
# public.profiles.id should reference auth.users.id.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Use the publishable key when available. The app falls back to the anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="replace-with-supabase-publishable-value"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-value"

# ============================================================================
# Supabase Server-only Environment
# ============================================================================
# Never expose this in browser code. Use only for trusted admin/server operations.
SUPABASE_SERVICE_ROLE_KEY="replace-with-server-only-supabase-value"

# ============================================================================
# Optional Prisma Tooling / Runtime DB Access
# ============================================================================
# DATABASE_URL is no longer used for account creation.
# Keep it valid temporarily because package.json still runs prisma generate before next build.
# TODO: Remove Prisma from the build later or align Prisma models with Supabase UUID tables.
DATABASE_URL="postgresql://username:password@host:5432/thegreenlist"

# ============================================================================
# Deprecated NextAuth.js Configuration
# ============================================================================
# Deprecated after Supabase Auth migration. Do not use for primary login/session flow.
# Keep only while unrelated legacy NextAuth files are being safely removed.
NEXTAUTH_URL="https://thegreenlist.online"
NEXTAUTH_SECRET="replace-with-legacy-nextauth-value"

# ============================================================================
# Deprecated / Optional OAuth Provider Values
# ============================================================================
# Supabase OAuth providers should be configured in the Supabase dashboard.
# These legacy NextAuth values are not used by the Supabase Auth login flow.
GOOGLE_CLIENT_ID="replace-with-legacy-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-legacy-google-secret"
APPLE_ID="replace-with-legacy-apple-id"
APPLE_SECRET="replace-with-legacy-apple-secret"

# ============================================================================
# Porkbun Domain Management
# ============================================================================
PORKBUN_API_KEY="replace-with-porkbun-api-key"
PORKBUN_API_SECRET="replace-with-porkbun-api-secret"
PORKBUN_DOMAIN="thegreenlist.online"
PORKBUN_SECONDARY_DOMAIN="greenlist.online"

# ============================================================================
# Vercel DNS Records
# ============================================================================
VERCEL_APEX_A_RECORD="216.198.79.1"
VERCEL_WWW_CNAME_RECORD="917519468536e383.vercel-dns-017.com."
INCLUDE_API_SUBDOMAIN="false"
VERCEL_API_CNAME_RECORD="917519468536e383.vercel-dns-017.com."

# ============================================================================
# Optional Services
# ============================================================================
OPENAI_API_KEY="replace-with-openai-api-key"
RESEND_API_KEY="replace-with-resend-api-key"
REDIS_URL="redis://cache.thegreenlist.online:6379"

# ============================================================================
# Analytics and Monitoring
# ============================================================================
VERCEL_ANALYTICS_ID="replace-with-vercel-analytics-id"
SENTRY_DSN="replace-with-sentry-dsn"

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_AI_MODERATION="true"
ENABLE_FORUMS="true"
ENABLE_REVIEWS="true"

# ============================================================================
# Future n8n Automation (Do not require for initial setup)
# ============================================================================
# N8N_WEBHOOK_URL="https://n8n.your-domain.com/webhook/"
# N8N_API_KEY="replace-with-n8n-api-key"
