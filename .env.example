# The Green List environment placeholders. Copy to .env.local and fill secrets locally.

# App
NEXT_PUBLIC_APP_URL=https://thegreenlist.online
NEXT_PUBLIC_SITE_URL=https://thegreenlist.online
NEXT_PUBLIC_SITE_NAME="The Green List"
NEXT_PUBLIC_DOMAIN=thegreenlist.online
NEXT_PUBLIC_SECONDARY_DOMAIN=greenlist.online

# NextAuth
NEXTAUTH_URL=https://thegreenlist.online
NEXTAUTH_SECRET=

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_ID=
APPLE_SECRET=

# Database
DATABASE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Porkbun/Vercel DNS
PORKBUN_API_KEY=
PORKBUN_API_SECRET=
PORKBUN_DOMAIN=thegreenlist.online
VERCEL_APEX_A_RECORD=216.198.79.1
VERCEL_WWW_CNAME_RECORD=917519468536e383.vercel-dns-017.com.
INCLUDE_API_SUBDOMAIN=false
VERCEL_API_CNAME_RECORD=

# Future n8n placeholders only. Do not require during build until an n8n feature is enabled.
N8N_WEBHOOK_URL=
N8N_API_KEY=
