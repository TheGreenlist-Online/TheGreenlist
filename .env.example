# Site Configuration
NEXT_PUBLIC_SITE_URL="https://thegreenlist.online"
NEXT_PUBLIC_DOMAIN="thegreenlist.online"
NEXT_PUBLIC_SECONDARY_DOMAIN="greenlist.online"

# NextAuth
NEXTAUTH_URL="https://thegreenlist.online"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Optional OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
APPLE_ID="your-apple-client-id"
APPLE_SECRET="your-apple-client-secret"

# Auth redirect/callback URLs to allow in providers:
# https://thegreenlist.online
# https://greenlist.online
# https://thegreenlist.online/api/auth/callback/google
# https://greenlist.online/api/auth/callback/google
# http://localhost:3000
# http://localhost:3000/api/auth/callback/google

# Porkbun Domain Management (https://porkbun.com)
PORKBUN_API_KEY="your-porkbun-api-key"
PORKBUN_API_SECRET="your-porkbun-api-secret"
PORKBUN_DOMAIN="thegreenlist.online"
PORKBUN_SECONDARY_DOMAIN="greenlist.online"

# Database (PostgreSQL or Supabase)
# Local development:
# DATABASE_URL="postgresql://username:password@localhost:5432/thegreenlist"
# Production (Supabase):
# DATABASE_URL="postgresql://postgres.your-project-ref:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL="postgresql://username:password@host:5432/thegreenlist"

# Supabase Storage / optional Supabase client usage
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# Server-only. Use only for trusted admin operations that require it.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Optional Services
OPENAI_API_KEY="your-openai-api-key"
REDIS_URL="redis://cache.thegreenlist.online:6379"
RESEND_API_KEY="your-resend-api-key"

# Analytics and Monitoring
VERCEL_ANALYTICS_ID="your-vercel-analytics-id"
SENTRY_DSN="your-sentry-dsn"

# Feature Flags
ENABLE_AI_MODERATION="true"
ENABLE_FORUMS="true"
ENABLE_REVIEWS="true"
