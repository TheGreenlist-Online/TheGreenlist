# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DOMAIN="localhost:3000"
NEXT_PUBLIC_SECONDARY_DOMAIN=""

# NextAuth
# Local development:
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Production values:
# NEXT_PUBLIC_SITE_URL="https://thegreenlist.online"
# NEXT_PUBLIC_DOMAIN="thegreenlist.online"
# NEXT_PUBLIC_SECONDARY_DOMAIN="greenlist.online"
# NEXTAUTH_URL="https://thegreenlist.online"
# NEXTAUTH_SECRET="generate-a-long-random-secret"

# Database (PostgreSQL or Supabase)
# Local development:
# DATABASE_URL="postgresql://username:password@localhost:5432/thegreenlist"
# Production (Supabase):
# DATABASE_URL="postgresql://postgres.your-project-ref:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL="postgresql://username:password@localhost:5432/thegreenlist"

# Optional OAuth Providers
# Google callback URLs:
# Local: http://localhost:3000/api/auth/callback/google
# Production: https://thegreenlist.online/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple callback URLs:
# Local: http://localhost:3000/api/auth/callback/apple
# Production: https://thegreenlist.online/api/auth/callback/apple
APPLE_ID=""
APPLE_SECRET=""

# Supabase Storage / optional Supabase client usage
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Use only for trusted admin operations that require it.
SUPABASE_SERVICE_ROLE_KEY=""

# Porkbun Domain Management (server-only)
PORKBUN_API_KEY=""
PORKBUN_API_SECRET=""
PORKBUN_DOMAIN="thegreenlist.online"
PORKBUN_SECONDARY_DOMAIN="greenlist.online"

# Optional Services
OPENAI_API_KEY=""
REDIS_URL=""
RESEND_API_KEY=""
VERCEL_ANALYTICS_ID=""
SENTRY_DSN=""

# Feature Flags
ENABLE_AI_MODERATION="true"
ENABLE_FORUMS="true"
ENABLE_REVIEWS="true"
