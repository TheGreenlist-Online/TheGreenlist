# ============================================================================
# The Green List Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# Never commit secrets to the repository.

# ============================================================================
# Site Configuration
# ============================================================================
NEXT_PUBLIC_SITE_URL="https://thegreenlist.online"
NEXT_PUBLIC_SITE_NAME="The Green List"
NEXT_PUBLIC_DOMAIN="thegreenlist.online"
NEXT_PUBLIC_SECONDARY_DOMAIN="greenlist.online"

# ============================================================================
# NextAuth.js Configuration
# ============================================================================
# Generate a secure random secret: openssl rand -base64 32
NEXTAUTH_URL="https://thegreenlist.online"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# ============================================================================
# Optional OAuth Providers
# ============================================================================
# Google OAuth:
# 1. Go to Google Cloud Console
# 2. Create OAuth 2.0 Client ID (Web Application)
# 3. Add authorized redirect URIs:
#    - https://thegreenlist.online/api/auth/callback/google
#    - https://greenlist.online/api/auth/callback/google
#    - http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Apple Sign-In:
APPLE_ID="your-apple-client-id"
APPLE_SECRET="your-apple-client-secret"

# ============================================================================
# Database Configuration
# ============================================================================
# Local development:
#   DATABASE_URL="postgresql://username:password@localhost:5432/thegreenlist"
#
# Production (Supabase):
#   DATABASE_URL="postgresql://postgres.your-project-ref:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# For pooled connections, add ?schema=public to the end if needed.
DATABASE_URL="postgresql://username:password@host:5432/thegreenlist"

# ============================================================================
# Supabase (Optional - for storage and additional services)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Server-only. Use sparingly for trusted admin operations.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ============================================================================
# Porkbun Domain Management
# ============================================================================
# Get API credentials from https://porkbun.com/account/apikeys
PORKBUN_API_KEY="your-porkbun-api-key"
PORKBUN_API_SECRET="your-porkbun-api-secret"
PORKBUN_DOMAIN="thegreenlist.online"
PORKBUN_SECONDARY_DOMAIN="greenlist.online"

# ============================================================================
# Vercel DNS Records
# ============================================================================
# Copy these exact values from your Vercel project domain settings.
# DO NOT hardcode these. Get them from Vercel first.
VERCEL_APEX_A_RECORD="216.198.79.1"
VERCEL_WWW_CNAME_RECORD="917519468536e383.vercel-dns-017.com."

# Optional: API subdomain for future use
INCLUDE_API_SUBDOMAIN="false"
VERCEL_API_CNAME_RECORD="917519468536e383.vercel-dns-017.com."

# ============================================================================
# Optional Services
# ============================================================================
# OpenAI (for content summarization and moderation)
OPENAI_API_KEY="your-openai-api-key"

# Resend (for email notifications)
RESEND_API_KEY="your-resend-api-key"

# Redis Cache (optional, for future caching)
REDIS_URL="redis://cache.thegreenlist.online:6379"

# ============================================================================
# Analytics and Monitoring
# ============================================================================
VERCEL_ANALYTICS_ID="your-vercel-analytics-id"
SENTRY_DSN="your-sentry-dsn"

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_AI_MODERATION="true"
ENABLE_FORUMS="true"
ENABLE_REVIEWS="true"

# ============================================================================
# Future n8n Automation (Do not require for initial setup)
# ============================================================================
# Uncomment and configure only when n8n automation is implemented.
# N8N_WEBHOOK_URL="https://n8n.your-domain.com/webhook/"
# N8N_API_KEY="your-n8n-api-key"
